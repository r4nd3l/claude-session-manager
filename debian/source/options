# Keep build artifacts and dev cruft out of the native source tarball.
tar-ignore = .git
tar-ignore = node_modules
tar-ignore = docs/node_modules
tar-ignore = docs/.vitepress/dist
tar-ignore = docs/.vitepress/cache
tar-ignore = .pybuild
tar-ignore = dist
tar-ignore = build
tar-ignore = "*.egg-info"
tar-ignore = __pycache__
tar-ignore = ".ruff_cache"
tar-ignore = ".pytest_cache"
tar-ignore = ".venv"
tar-ignore = "*.deb"
tar-ignore = debian/.debhelper
tar-ignore = debian/claude-session-manager
tar-ignore = debian/files
tar-ignore = "debian/*.substvars"
tar-ignore = "debian/*.debhelper"
tar-ignore = debian/debhelper-build-stamp
